<UserControl x:Class="JetCutPlugin.JetCutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Width="580" MinHeight="680">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- テキスト色 — YMM4のテーマに左右されないよう明示指定 -->
        <SolidColorBrush x:Key="FG" Color="#202020"/>
        <SolidColorBrush x:Key="FGSub" Color="#555555"/>
        <SolidColorBrush x:Key="BorderColor" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="BG" Color="#F8F8F8"/>

        <Style x:Key="H" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,10,0,4"/>
            <Setter Property="Foreground" Value="{StaticResource FG}"/>
        </Style>
        <Style x:Key="L" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource FG}"/>
        </Style>
        <Style x:Key="V" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="MinWidth" Value="60"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource FG}"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="3,2"/>
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="Foreground" Value="#202020"/>
            <Setter Property="BorderBrush" Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="4,4"/>
            <Setter Property="Background" Value="#3B82F6"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Padding" Value="18,9"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="4,4"/>
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#DC2626"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource BG}">
        <StackPanel Margin="16">

            <!-- ===== タイトル ===== -->
            <TextBlock Text="✂ ジェットカット" FontSize="20" FontWeight="Bold" Margin="0,0,0,2"
                       Foreground="{StaticResource FG}"/>
            <TextBlock FontSize="11" Margin="0,0,0,10" TextWrapping="Wrap" Foreground="{StaticResource FGSub}">
                <Run Text="タイムライン上の動画・音声の無音部分を自動検出してカットします。"/>
                <LineBreak/>
                <Run Text="① 解析 → ② カットする区間を選択 → ③ カット実行"/>
            </TextBlock>

            <!-- ===== STEP 0: プロジェクト ===== -->
            <TextBlock Text="📂 プロジェクト" Style="{StaticResource H}"/>
            <Border BorderBrush="{StaticResource BorderColor}" Background="White"
                    BorderThickness="1" CornerRadius="3" Padding="10,8" Margin="0,0,0,4">
                <StackPanel>
                    <DockPanel Margin="0,0,0,4">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button Content="自動検出" Command="{Binding DetectCommand}" Style="{StaticResource Btn}"/>
                            <Button Content="追加" Command="{Binding AddCommand}" Style="{StaticResource Btn}"/>
                            <Button Content="削除" Command="{Binding RemoveCommand}" Style="{StaticResource Btn}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ProjectSummary}" Style="{StaticResource L}" FontWeight="SemiBold"/>
                    </DockPanel>
                    <ListBox ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}"
                             Height="48" FontSize="11" DisplayMemberPath="DisplayName"
                             Background="White" Foreground="{StaticResource FG}"/>
                </StackPanel>
            </Border>

            <!-- ===== メディアファイル ===== -->
            <TextBlock Text="🎬 検出されたメディアファイル" Style="{StaticResource H}"/>
            <ItemsControl ItemsSource="{Binding MediaFiles}" Margin="4,0,0,4" MaxHeight="80">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <DockPanel Margin="0,1">
                            <TextBlock Text="{Binding Status}" DockPanel.Dock="Right" FontSize="11"
                                       Foreground="{StaticResource FGSub}" Margin="8,0,0,0"/>
                            <TextBlock Text="{Binding FileName}" FontSize="11" TextTrimming="CharacterEllipsis"
                                       Foreground="{StaticResource FG}"/>
                        </DockPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ===== STEP 1: パラメータ ===== -->
            <TextBlock Text="⚙ パラメータ" Style="{StaticResource H}"/>
            <Border BorderBrush="{StaticResource BorderColor}" Background="White"
                    BorderThickness="1" CornerRadius="3" Padding="12,8" Margin="0,0,0,4">
                <StackPanel>
                    <TextBlock Text="▶ 解析開始位置（秒）" Style="{StaticResource L}" Margin="0,0,0,3"/>
                    <DockPanel>
                        <TextBlock Text="{Binding StartPositionText}" Style="{StaticResource V}" DockPanel.Dock="Right"/>
                        <Slider Value="{Binding StartPositionSec}" Minimum="0" Maximum="3600"
                                TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                    </DockPanel>

                    <TextBlock Text="🔊 音量閾値（dB）— この値以下を無音とみなす" Style="{StaticResource L}" Margin="0,10,0,3"/>
                    <DockPanel>
                        <TextBlock Text="{Binding ThresholdDbText}" Style="{StaticResource V}" DockPanel.Dock="Right"/>
                        <Slider Value="{Binding ThresholdDb}" Minimum="-60" Maximum="0"
                                TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                    </DockPanel>

                    <TextBlock Text="⏱ 最小無音時間（秒）— これ以上の無音をカット" Style="{StaticResource L}" Margin="0,10,0,3"/>
                    <DockPanel>
                        <TextBlock Text="{Binding MinSilenceText}" Style="{StaticResource V}" DockPanel.Dock="Right"/>
                        <Slider Value="{Binding MinSilenceSec}" Minimum="0.1" Maximum="5.0"
                                TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                    </DockPanel>

                    <TextBlock Text="↔ マージン（秒）— カットの前後に残す余白" Style="{StaticResource L}" Margin="0,10,0,3"/>
                    <DockPanel>
                        <TextBlock Text="{Binding MarginText}" Style="{StaticResource V}" DockPanel.Dock="Right"/>
                        <Slider Value="{Binding MarginSec}" Minimum="0" Maximum="1.0"
                                TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- ===== 解析ボタン ===== -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8">
                <Button Content="🔍 解析する" Style="{StaticResource AccentBtn}"
                        Command="{Binding AnalyzeCommand}" MinWidth="160"/>
                <Button Content="キャンセル" Style="{StaticResource Btn}" Command="{Binding CancelCommand}"
                        Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <!-- 進捗 -->
            <ProgressBar Value="{Binding Progress}" Height="6" Margin="0,0,0,2"
                         Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"
                         Foreground="#3B82F6"/>
            <TextBlock Text="{Binding StatusText}" FontSize="12" Margin="0,3" TextWrapping="Wrap"
                       Foreground="{StaticResource FG}"/>

            <!-- ===== STEP 2: 解析結果 ===== -->
            <Border BorderBrush="#86EFAC" Background="#F0FDF4"
                    BorderThickness="1" CornerRadius="3" Padding="12,8" Margin="0,6,0,0"
                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ResultText}" TextWrapping="Wrap" FontSize="12" Foreground="#166534"/>
            </Border>

            <!-- 無音区間リスト -->
            <DockPanel Margin="0,4,0,0" Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,4,0,3">
                    <TextBlock Text="🔇 無音区間" Style="{StaticResource H}" Margin="0,0,8,0"/>
                    <Button Content="全選択" Command="{Binding SelectAllCommand}" Style="{StaticResource Btn}"/>
                    <Button Content="全解除" Command="{Binding DeselectAllCommand}" Style="{StaticResource Btn}"/>
                </StackPanel>
                <TextBlock Text="{Binding SelectionSummary}" DockPanel.Dock="Top" FontSize="11" Margin="4,0,0,4"
                           Foreground="{StaticResource FGSub}"/>
                <ListBox ItemsSource="{Binding SilentRegions}" Height="180" FontSize="11" FontFamily="Consolas"
                         Background="White" Foreground="{StaticResource FG}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding DisplayText}" Margin="2,1"
                                      Foreground="{StaticResource FG}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- ===== STEP 3: カット実行 ===== -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8"
                        Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                <Button Content="✂ 選択した区間をカット実行" Style="{StaticResource DangerBtn}"
                        Command="{Binding CutCommand}" MinWidth="280"/>
            </StackPanel>

            <!-- ===== ログ ===== -->
            <TextBlock Text="📋 ログ" Style="{StaticResource H}"/>
            <TextBox Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap"
                     VerticalScrollBarVisibility="Auto" Height="120" FontSize="10.5" FontFamily="Consolas"
                     Padding="6" Background="White" Foreground="{StaticResource FG}" 
                     BorderBrush="{StaticResource BorderColor}"/>
        </StackPanel>
    </ScrollViewer>
</UserControl>
