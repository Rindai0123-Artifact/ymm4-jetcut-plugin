<UserControl x:Class="JetCutPlugin.JetCutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <SolidColorBrush x:Key="FG" Color="#202020"/>
        <SolidColorBrush x:Key="FGSub" Color="#555555"/>
        <SolidColorBrush x:Key="BorderColor" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="BG" Color="#F8F8F8"/>

        <Style x:Key="H" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,6,0,3"/>
            <Setter Property="Foreground" Value="{StaticResource FG}"/>
        </Style>
        <Style x:Key="L" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Foreground" Value="{StaticResource FG}"/>
        </Style>
        <Style x:Key="V" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="HorizontalAlignment" Value="Right"/>
            <Setter Property="MinWidth" Value="55"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource FG}"/>
        </Style>
        <Style x:Key="Btn" TargetType="Button">
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="2,1"/>
            <Setter Property="Background" Value="#E8E8E8"/>
            <Setter Property="Foreground" Value="#202020"/>
            <Setter Property="BorderBrush" Value="#BBBBBB"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="AccentBtn" TargetType="Button">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="3,3"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#3B82F6" BorderBrush="#2563EB" BorderThickness="1"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="White" TextBlock.FontWeight="SemiBold"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerBtn" TargetType="Button">
            <Setter Property="Padding" Value="14,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="3,3"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="#FCA5A5" BorderBrush="#EF4444" BorderThickness="1"
                                CornerRadius="3" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextBlock.Foreground="#991B1B" TextBlock.FontWeight="Bold"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="Exp" TargetType="Expander">
            <Setter Property="Foreground" Value="{StaticResource FG}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
    </UserControl.Resources>

    <!-- レスポンシブ: 固定Width/MinHeight なし。親コンテナに追従 -->
    <ScrollViewer VerticalScrollBarVisibility="Auto" Background="{StaticResource BG}">
        <StackPanel Margin="12,8,12,12">

            <!-- タイトル -->
            <TextBlock Text="✂ ジェットカット v2.0" FontSize="18" FontWeight="Bold" Margin="0,0,0,1"
                       Foreground="{StaticResource FG}"/>
            <TextBlock FontSize="10" Margin="0,0,0,6" TextWrapping="Wrap" Foreground="{StaticResource FGSub}"
                       Text="① メディア選択 → ② 解析 → ③ 区間選択 → ④ カット実行"/>

            <!-- ===== プロジェクト ===== -->
            <Border BorderBrush="{StaticResource BorderColor}" Background="White"
                    BorderThickness="1" CornerRadius="3" Padding="8,6" Margin="0,0,0,3">
                <StackPanel>
                    <DockPanel>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button Content="自動検出" Command="{Binding DetectCommand}" Style="{StaticResource Btn}"/>
                            <Button Content="追加" Command="{Binding AddCommand}" Style="{StaticResource Btn}"/>
                            <Button Content="削除" Command="{Binding RemoveCommand}" Style="{StaticResource Btn}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ProjectSummary}" Style="{StaticResource L}" FontWeight="SemiBold"/>
                    </DockPanel>
                    <ListBox ItemsSource="{Binding Projects}" SelectedItem="{Binding SelectedProject}"
                             MinHeight="24" MaxHeight="45" FontSize="10" DisplayMemberPath="DisplayName"
                             Background="White" Foreground="{StaticResource FG}" Margin="0,3,0,0"/>
                </StackPanel>
            </Border>

            <!-- ===== メディアファイル選択 ===== -->
            <DockPanel Margin="0,2,0,0">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top">
                    <TextBlock Text="🎬 メディアファイル" Style="{StaticResource H}" Margin="0,0,6,0"/>
                    <Button Content="全選択" Command="{Binding SelectAllMediaCommand}" Style="{StaticResource Btn}"/>
                    <Button Content="全解除" Command="{Binding DeselectAllMediaCommand}" Style="{StaticResource Btn}"/>
                </StackPanel>
                <Border BorderBrush="{StaticResource BorderColor}" Background="White"
                        BorderThickness="1" CornerRadius="3" Padding="4,2" Margin="0,2,0,0">
                    <ListBox ItemsSource="{Binding MediaFiles}" MinHeight="28" MaxHeight="90"
                             FontSize="10" Background="White" Foreground="{StaticResource FG}"
                             BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <DockPanel>
                                    <TextBlock Text="{Binding Status}" DockPanel.Dock="Right" FontSize="10"
                                               Foreground="{StaticResource FGSub}" Margin="6,0,0,0"/>
                                    <TextBlock Text="{Binding SegmentInfo}" DockPanel.Dock="Right" FontSize="9"
                                               Foreground="#888" Margin="4,0,0,0"/>
                                    <CheckBox IsChecked="{Binding IsSelected}" VerticalAlignment="Center"
                                              Margin="0,0,4,0"/>
                                    <TextBlock Text="{Binding FileName}" FontSize="10" TextTrimming="CharacterEllipsis"
                                               Foreground="{StaticResource FG}" VerticalAlignment="Center"/>
                                </DockPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </DockPanel>

            <!-- ===== パラメータ（折りたたみ可能） ===== -->
            <Expander Header="⚙ パラメータ設定" IsExpanded="True" Style="{StaticResource Exp}">
                <Border BorderBrush="{StaticResource BorderColor}" Background="White"
                        BorderThickness="1" CornerRadius="3" Padding="10,6" Margin="0,2,0,0">
                    <StackPanel>
                        <TextBlock Style="{StaticResource L}" Margin="0,0,0,2" TextWrapping="Wrap">
                            <Run Text="▶ 解析開始位置" FontWeight="SemiBold"/>
                            <Run Text="  タイムラインのこの位置以降にあるアイテムだけを解析します" Foreground="#888"/>
                        </TextBlock>
                        <DockPanel>
                            <TextBlock Text="{Binding StartPositionText}" Style="{StaticResource V}" DockPanel.Dock="Right"/>
                            <Slider Value="{Binding StartPositionSec}" Minimum="0" Maximum="3600"
                                    TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                        </DockPanel>

                        <TextBlock Style="{StaticResource L}" Margin="0,6,0,2" TextWrapping="Wrap">
                            <Run Text="🔊 音量閾値（dB）" FontWeight="SemiBold"/>
                            <Run Text="  この値以下の音量を「無音」と判定します" Foreground="#888"/>
                        </TextBlock>
                        <DockPanel>
                            <TextBlock Text="{Binding ThresholdDbText}" Style="{StaticResource V}" DockPanel.Dock="Right"/>
                            <Slider Value="{Binding ThresholdDb}" Minimum="-60" Maximum="0"
                                    TickFrequency="5" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                        </DockPanel>

                        <TextBlock Style="{StaticResource L}" Margin="0,6,0,2" TextWrapping="Wrap">
                            <Run Text="⏱ 最小無音時間（秒）" FontWeight="SemiBold"/>
                            <Run Text="  この長さ以上続く無音だけをカット対象にします" Foreground="#888"/>
                        </TextBlock>
                        <DockPanel>
                            <TextBlock Text="{Binding MinSilenceText}" Style="{StaticResource V}" DockPanel.Dock="Right"/>
                            <Slider Value="{Binding MinSilenceSec}" Minimum="0.1" Maximum="5.0"
                                    TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                        </DockPanel>

                        <TextBlock Style="{StaticResource L}" Margin="0,6,0,2" TextWrapping="Wrap">
                            <Run Text="↔ マージン（秒）" FontWeight="SemiBold"/>
                            <Run Text="  無音カットの前後にこの長さだけ余白を残します。話し始め・話し終わりが切れるのを防ぎます" Foreground="#888"/>
                        </TextBlock>
                        <DockPanel>
                            <TextBlock Text="{Binding MarginText}" Style="{StaticResource V}" DockPanel.Dock="Right"/>
                            <Slider Value="{Binding MarginSec}" Minimum="0" Maximum="1.0"
                                    TickFrequency="0.05" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                        </DockPanel>
                    </StackPanel>
                </Border>
            </Expander>

            <!-- ===== 解析ボタン ===== -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6">
                <Button Content="🔍 解析する" Style="{StaticResource AccentBtn}"
                        Command="{Binding AnalyzeCommand}" MinWidth="130"/>
                <Button Content="キャンセル" Style="{StaticResource Btn}" Command="{Binding CancelCommand}"
                        Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>

            <!-- 進捗 -->
            <ProgressBar Value="{Binding Progress}" Height="4" Margin="0,0,0,1"
                         Visibility="{Binding IsProcessing, Converter={StaticResource BoolToVis}}"
                         Foreground="#3B82F6"/>
            <TextBlock Text="{Binding StatusText}" FontSize="11" Margin="0,2" TextWrapping="Wrap"
                       Foreground="{StaticResource FG}"/>

            <!-- ===== 解析結果 ===== -->
            <Border BorderBrush="#86EFAC" Background="#F0FDF4"
                    BorderThickness="1" CornerRadius="3" Padding="10,6" Margin="0,4,0,0"
                    Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="{Binding ResultText}" TextWrapping="Wrap" FontSize="11" Foreground="#166534"/>
            </Border>

            <!-- ===== 無音区間リスト ===== -->
            <DockPanel Margin="0,3,0,0" Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,2,0,2">
                    <TextBlock Text="🔇 無音区間" Style="{StaticResource H}" Margin="0,0,6,0"/>
                    <Button Content="全選択" Command="{Binding SelectAllCommand}" Style="{StaticResource Btn}"/>
                    <Button Content="全解除" Command="{Binding DeselectAllCommand}" Style="{StaticResource Btn}"/>
                </StackPanel>
                <TextBlock Text="{Binding SelectionSummary}" DockPanel.Dock="Top" FontSize="10" Margin="4,0,0,2"
                           Foreground="{StaticResource FGSub}"/>
                <ListBox ItemsSource="{Binding SilentRegions}" MinHeight="60" MaxHeight="200"
                         FontSize="10" FontFamily="Consolas"
                         Background="White" Foreground="{StaticResource FG}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected}" Content="{Binding DisplayText}" Margin="1,0"
                                      Foreground="{StaticResource FG}"/>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- ===== カット実行ボタン ===== -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,6"
                        Visibility="{Binding HasResult, Converter={StaticResource BoolToVis}}">
                <Button Content="✂ 選択した区間をカット実行" Style="{StaticResource DangerBtn}"
                        Command="{Binding CutCommand}" MinWidth="240"/>
            </StackPanel>

            <!-- ===== ログ（折りたたみ可能） ===== -->
            <Expander Header="📋 ログ" IsExpanded="False" Style="{StaticResource Exp}">
                <TextBox Text="{Binding LogText, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" MinHeight="60" MaxHeight="150"
                         FontSize="10" FontFamily="Consolas"
                         Padding="4" Background="White" Foreground="{StaticResource FG}"
                         BorderBrush="{StaticResource BorderColor}"/>
            </Expander>
        </StackPanel>
    </ScrollViewer>
</UserControl>
